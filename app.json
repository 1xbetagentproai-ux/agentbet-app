{
  "expo": {
    "name": "1xBet Agent Pro",
    "slug": "1xbet-agent-pro",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "splash": {
      "backgroundColor": "#2563EB"
    },
    "assetBundlePatterns": ["**/*"],
    "plugins": [
      [
        "expo-image-picker",
        {
          "photosPermission": "AgentBet a besoin d'accéder à vos photos pour télécharger une preuve de paiement.",
          "cameraPermission": "AgentBet a besoin d'accéder à votre appareil photo pour prendre une preuve de paiement."
        }
      ]
    ],
    "android": {
      "package": "com.mozart.xbetagentpro",
      "versionCode": 1,
      "adaptiveIcon": {
        "backgroundColor": "#2563EB"
      },
      "permissions": ["CAMERA", "READ_EXTERNAL_STORAGE", "WRITE_EXTERNAL_STORAGE"]
    },
    "ios": {
      "bundleIdentifier": "com.mozart.xbetagentpro",
      "supportsTablet": false
    },
    "extra": {
      "eas": {
        "projectId": "REMPLACER_APRES_EAS_INIT"
      }
    }
  }
}
